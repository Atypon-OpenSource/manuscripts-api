{
  "name": "@manuscripts/api",
  "version": "2.3.6",
  "description": "Manuscripts API server",
  "license": "Apache-2.0",
  "main": "dist/index",
  "repository": "github:Atypon-OpenSource/manuscripts-api",
  "scripts": {
    "dev": "ts-node --transpile-only --files src",
    "start": "run-s build run",
    "run": "node dist/index",
    "build": "run-s generate-prisma build-app",
    "build-app": "tsc",
    "generate-prisma": "prisma generate",
    "migrate-prisma": "prisma migrate dev --name init",
    "migrate-prisma-deploy": "npx prisma migrate deploy && node ./prisma/migrations/20240611191311_init/patch.js",
    "lint": "eslint src --ext .js,.ts",
    "typecheck": "tsc --noEmit",
    "test": "run-s test:unit test:int",
    "test:unit": "jest --ci --config=./jest.config.unit.test.js --no-cache --detectOpenHandles --forceExit --coverage --runInBand --reporters=default",
    "test:unit:dev": "jest --config=./jest.config.unit.test.js --runInBand --watch",
    "test:int": "NODE_OPTIONS=--max_old_space_size=4096 jest --ci --config=./jest.config.int.test.js --no-cache --forceExit --coverage --reporters=default --runInBand --logHeapUsage --bail  --detectOpenHandles",
    "test:int:dev": "jest --config=./jest.config.int.test.js --runInBand --watch",
    "debug-test:int": "NODE_OPTIONS=--max_old_space_size=4096 node --inspect-brk ./node_modules/.bin/jest --config=./jest.config.int.test.js --no-cache --runInBand",
    "clean": "rm -rf dist/",
    "prepare": "node -e \"process.env.CI || require('child_process').execSync('husky', {stdio:'inherit'})\"",
    "preversion": "pnpm typecheck && pnpm lint"
  },
  "dependencies": {
    "@manuscripts/transform": "4.4.5",
    "@prisma/client": "6.19.3",
    "celebrate": "15.0.3",
    "checksum": "1.0.0",
    "cors": "2.8.6",
    "crypto-random-string": "5.0.0",
    "decompress": "4.2.1",
    "dotenv-safe": "9.1.0",
    "express": "5.2.1",
    "express-prom-bundle": "8.0.0",
    "fs-extra": "11.3.5",
    "get-stream": "6.0.1",
    "http-status-codes": "2.3.0",
    "joi": "17.13.3",
    "jsdom": "26.1.0",
    "jsonwebtoken": "9.0.3",
    "jszip": "3.10.1",
    "lodash": "4.18.1",
    "morgan": "1.10.1",
    "multer": "1.4.5-lts.2",
    "oembed-providers": "1.0.20260421",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "prom-client": "15.1.3",
    "prosemirror-transform": "1.10.4",
    "semver": "7.8.0",
    "swagger-ui-express": "5.0.1",
    "uuid": "10.0.0",
    "winston": "3.19.0",
    "ws": "8.20.1",
    "yaml": "2.9.0",
    "prisma": "6.19.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@jest-mock/express": "3.0.0",
    "@manuscripts/eslint-config": "0.5.1",
    "@types/bcrypt": "5.0.2",
    "@types/chance": "1.1.8",
    "@types/checksum": "0.1.35",
    "@types/cors": "2.8.19",
    "@types/decompress": "4.2.7",
    "@types/dotenv-safe": "8.1.6",
    "@types/express": "5.0.6",
    "@types/fs-extra": "11.0.4",
    "@types/jest": "29.5.14",
    "@types/jsdom": "21.1.7",
    "@types/jsonwebtoken": "9.0.10",
    "@types/lodash": "4.17.24",
    "@types/morgan": "1.9.10",
    "@types/multer": "1.4.13",
    "@types/passport": "1.0.17",
    "@types/passport-jwt": "3.0.13",
    "@types/semver": "7.7.1",
    "@types/supertest": "2.0.16",
    "@types/swagger-ui-express": "4.1.8",
    "@types/uuid": "10.0.0",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "babel-jest": "29.7.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-diff": "2.1.7",
    "eslint-plugin-header": "3.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "jest": "29.7.0",
    "jest-circus": "29.7.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "husky": "9.1.7",
    "typescript": "5.9.2"
  }
}