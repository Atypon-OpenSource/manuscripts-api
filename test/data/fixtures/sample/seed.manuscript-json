      }
    ],
    "containedObjectIDs": [
      "MPParagraphElement:31A372BC-DA25-474A-849B-74A8F05E11AC"
    ],
    "position": "float",
    "_id": "MPFigure:CC4AA7CA-77D6-40F6-AC58-04E0C1654A59",
