    "manuscriptID": "MPManuscript:9E0BEDBC-1084-4AA1-AB82-10ACFAE02232"
  },
  {
    "elementType": "p",
    "contents": "<p xmlns=\"http://www.w3.org/1999/xhtml\" id=\"MPParagraphElement:D671A493-59B4-448B-AFCC-C24B63DD125F\" class=\"MPElement\" data-object-type=\"MPParagraphElement\">Source: World Bank Group, Map of SME-Support Measure in Response to COVID-19. <a href=\"https://www.worldbank.org/en/data/interactive/2020/04/14/map-of-sme-support-measures-in-response-to-covid-19\">https://www.worldbank.org/en/data/interactive/2020/04/14/map-of-sme-support-measures-in-response-to-covid-19</a></p>",
    "placeholderInnerHTML": "",
    "_id": "MPParagraphElement:D671A493-59B4-448B-AFCC-C24B63DD125F",
