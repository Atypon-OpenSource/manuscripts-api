  {
    "priority": 4,
    "title": "Prevalence of SMEs in affected countries and sectors",
    "label": "2.1",
    "path": [
      "MPSection:C4E6014F-6FCB-4B3D-8233-4E53228DF976",
      "MPSection:D8B4A95F-C1B6-4C53-8E35-97669473D511"
    ],
    "elementIDs": [
      "MPParagraphElement:9295ACCD-3169-441F-A73B-892120F7A6CA",
      "MPParagraphElement:CAE7C0D8-96D3-4250-98FE-62A347760791",
      "MPFigureElement:0E600FE4-D9F6-4524-B920-DEB37A6ABE1D",
