  {
    "priority": 11,
    "title": "How are governments supporting SMEs during the crisis?",
    "label": "4.1",
    "path": [
      "MPSection:89D1647F-87C0-42A1-8537-A72FBB384124",
      "MPSection:3A7F9E08-D1FB-48C1-96F6-E017A657753C"
