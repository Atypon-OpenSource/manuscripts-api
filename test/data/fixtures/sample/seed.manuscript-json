  {
    "priority": 10,
    "title": "DFIs are better positioned to help SMEs in the recovery rather than the crisis",
    "label": "4",
    "path": ["MPSection:89D1647F-87C0-42A1-8537-A72FBB384124"],
    "elementIDs": [
      "MPParagraphElement:587F12AF-1079-4D3E-A4FC-3C9C2F570EB4",
