  {
    "elementType": "p",
    "contents": "<p xmlns=\"http://www.w3.org/1999/xhtml\" id=\"MPParagraphElement:2825C1F9-A126-4563-A346-199D6A30E5A3\" class=\"MPElement\" data-object-type=\"MPParagraphElement\">Note: Stratification weights adjusted for the follow-up enterprise surveys according to median eligibility were used to produce the estimates. The weights account for non-response, assuming that businesses that could not be re-contacted (unobtainable) have exited the market</p>",
    "placeholderInnerHTML": "",
    "_id": "MPParagraphElement:2825C1F9-A126-4563-A346-199D6A30E5A3",
