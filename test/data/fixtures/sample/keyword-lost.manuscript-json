    {
      "_id": "MPParagraphElement:CC04E058-4494-44CA-93EB-96292E01EED9",
      "contents": "<p xmlns=\"http://www.w3.org/1999/xhtml\" id=\"MPParagraphElement:CC04E058-4494-44CA-93EB-96292E01EED9\" class=\"MPElement\" data-object-type=\"MPParagraphElement\">Patients with schizophrenia are at a higher risk for suicide compared with the general population. Dopamine-beta-hydroxylase (DβH) plays a key role in the conversion of dopamine to norepinephrine, which is related to suicidal behavior and cognitive regulation.</p>",
      "createdAt": 1689589036,
      "sessionID": "579459a9-d137-4b7f-8996-db10bd057ae5",
      "updatedAt": 1689589036,
      "_revisions": {
        "ids": [
          "0-922d92cb-a043-4431-b8fc-f97f5fcdcc7e"
        ]
      },
      "objectType": "MPParagraphElement",
