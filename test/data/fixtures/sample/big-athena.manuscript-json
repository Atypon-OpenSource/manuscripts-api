      "title": "4.5. Single-Photon Emission Computed Tomography (SPECT)",
      "priority": 23,
      "createdAt": 1694167156,
      "updatedAt": 1694167156,
      "elementIDs": ["MPParagraphElement:7BA9345D-5E53-4BAE-9883-5F3397FEF89B"],
      "objectType": "MPSection",
      "containerID": "MPProject:c4855a02-050a-452c-af9d-3a2e4501a96e",
