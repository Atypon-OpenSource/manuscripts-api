      "title": "11.3.4. Ground-Glass Opacity Nodules",
      "priority": 108,
      "createdAt": 1694167156,
      "updatedAt": 1694167156,
      "elementIDs": ["MPParagraphElement:1E3C4925-FC1B-4627-9356-83778D7870E9"],
