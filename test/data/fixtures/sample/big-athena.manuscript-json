        "MPSection:407BEC9F-4854-44E5-98A9-BC9BA4B36D44"
      ],
      "title": "4.3. Magnetic Resonance Imaging (MRI)",
      "priority": 21,
      "createdAt": 1694167156,
      "updatedAt": 1694167156,
      "elementIDs": ["MPParagraphElement:7E33602A-9B68-4284-8577-C838D4D8B2E4"],
      "objectType": "MPSection",
      "containerID": "MPProject:c4855a02-050a-452c-af9d-3a2e4501a96e",
