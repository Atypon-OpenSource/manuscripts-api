      "title": "Abstract",
      "category": "MPSectionCategory:abstract",
      "priority": 2,
      "createdAt": 1695029392,
      "updatedAt": 1695029392,
      "elementIDs": [
        "MPParagraphElement:A19E63CA-6778-4A23-B326-CAF506ECBA49"
      ],
      "objectType": "MPSection",
      "containerID": "MPProject:4831e2fe-e2c8-49d5-bfe0-99068de69af2",
