      "title": "2.6. Biometal Dyshomeostasis",
      "priority": 11,
      "createdAt": 1695029392,
      "updatedAt": 1695029392,
      "elementIDs": [
        "MPParagraphElement:32C330BF-B93A-4701-8207-6B42215C7BBA"
      ],
      "objectType": "MPSection",
      "containerID": "MPProject:4831e2fe-e2c8-49d5-bfe0-99068de69af2",
