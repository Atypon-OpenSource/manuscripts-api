    {
      "_id": "MPFigure:400D2023-0B6F-489B-9745-A93E418E12AB",
      "src": "attachment:14e57428-1c6f-4e2d-8f13-901d03cdf5ac",
      "createdAt": 1695029392,
      "updatedAt": 1695029392,
      "objectType": "MPFigure",
      "containerID": "MPProject:4831e2fe-e2c8-49d5-bfe0-99068de69af2",
