      "_id": "MPFigure:FAF877B0-CA60-4E43-9C5F-0FDEEAD09337",
      "src": "attachment:e6b5fede-322b-43ee-a981-68c72225d9cb",
      "createdAt": 1695029392,
      "updatedAt": 1695029392,
      "objectType": "MPFigure",
      "containerID": "MPProject:4831e2fe-e2c8-49d5-bfe0-99068de69af2",
